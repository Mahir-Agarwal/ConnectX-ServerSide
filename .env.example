# ConnectX Environment Variables
# Rename this file to .env or set these in your deployment dashboard/IDE

# Required: The secret key for signing JWT tokens.
# Must be at least 64 characters long for HS512.
JWT_SECRET=replace_this_with_a_long_secure_random_string_for_production

# Optional: The URL of the Eureka Discovery Server
# Defaults to http://localhost:8761/eureka if not set
EUREKA_URI=http://localhost:8761/eureka

# Optional: Redis Configuration
# Defaults to localhost:6379 with no password
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
